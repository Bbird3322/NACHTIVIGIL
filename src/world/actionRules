/**
 * NPCのタイプ・状態に応じた行動帯域キーを返す
 * @param {"enemy"|"informant"|"superior"|"investigator"|"media"|"agency"} type
 * @param {object} npcState - npcStates[id]
 * @param {object} npc - registry の NPC オブジェクト
 * @param {object} GS - ゲームステート
 * @returns {string} 帯域キー
 */
export function resolveBand(type, npcState, npc, GS) {
  switch (type) {
    case "enemy": {
      const al = npcState?.alertLevel ?? 0;
      if (al < 0.3) return "low_alert";
      if (al < 0.7) return "mid_alert";
      return "high_alert";
    }
    case "informant": {
      const loy = npc?.loyalty ?? 50;
      if (loy >= 70) return "high_loyalty";
      if (loy >= 30) return "mid_loyalty";
      return "low_loyalty";
    }
    case "superior": {
      const maxPressure = Math.max(0, ...Object.values(GS.bureaucracyPressure ?? {}));
      return maxPressure >= 0.6 ? "high_pressure" : "default";
    }
    case "investigator": {
      const fat = npc?.fatigue ?? 0;
      if (fat < 30) return "fresh";
      if (fat < 70) return "tired";
      return "exhausted";
    }
    case "media": {
      return GS.meters.PressHeat >= 0.3 ? "high_interest" : "low_interest";
    }
    case "agency": {
      // bureaucracyPressure の当該官庁エントリで判断
      const pressure = GS.bureaucracyPressure?.[npc?.org] ?? 0;
      return pressure >= 0.5 ? "hostile" : "cooperative";
    }
    default:
      return "default";
  }
}
 
/**
 * 確率テーブルから1つの行動をサンプリングする（multinomial）
 * @param {object} table - { action: weight, ... }
 * @returns {string} 選ばれた行動名
 */
export function sampleAction(table) {
  const total   = Object.values(table).reduce((s, w) => s + w, 0);
  let   rand    = Math.random() * total;
  for (const [action, weight] of Object.entries(table)) {
    rand -= weight;
    if (rand <= 0) return action;
  }
  // フォールバック（浮動小数点誤差対策）
  return Object.keys(table)[Object.keys(table).length - 1];
}
 
/**
 * NPC の行動を決定して返す
 * @param {"enemy"|"informant"|"superior"|"investigator"|"media"|"agency"} type
 * @param {object} npcState
 * @param {object} npc
 * @param {object} GS
 * @returns {string} 行動名
 */
export function decideAction(type, npcState, npc, GS) {
  const rules = ACTION_RULES[type];
  if (!rules) return "idle";
 
  const band  = resolveBand(type, npcState, npc, GS);
  const table = rules[band] ?? rules[Object.keys(rules)[0]];
  return sampleAction(table);
}