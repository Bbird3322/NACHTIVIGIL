// src/core/mechanics.js
// ダイス・日付・予算・フラグ判定・シナリオ固有チェック
// LLMを一切使わないルールベース処理
 
import { GS, addLog, setMeter } from "./gameState.js";
import { tickOperation } from "../ui/opPanel.js";
 
// ─────────────────────────────────────────────
// ダイス
// ─────────────────────────────────────────────
 
/** D100 ロール（1〜100）。結果を GS.lastD100 に記録 */
export function rollD100() {
  GS.lastD100 = Math.floor(Math.random() * 100) + 1;
  return GS.lastD100;
}
 
/** D6 ロール（1〜6）。結果を GS.lastD6 に記録 */
export function rollD6() {
  GS.lastD6 = Math.floor(Math.random() * 6) + 1;
  return GS.lastD6;
}
 
/**
 * スキルチェック。skill（0〜100）を参照してD100と比較。
 * @param {number} skill - 0〜100
 * @param {number} [modifier=0] - ボーナス/ペナルティ（±値）
 * @returns {"critical_success"|"success"|"failure"|"critical_failure"}
 */
export function skillCheck(skill, modifier = 0) {
  const roll = rollD100();
  const threshold = Math.max(5, Math.min(95, skill + modifier));
  if (roll <= Math.floor(threshold * 0.1))  return "critical_success";
  if (roll <= threshold)                     return "success";
  if (roll >= 96)                            return "critical_failure";
  return "failure";
}
 
// ─────────────────────────────────────────────
// 日付
// ─────────────────────────────────────────────
 
/**
 * ISO8601日付文字列を1日進める
 * @param {string} dateStr - "YYYY-MM-DD"
 * @returns {string}
 */
export function advanceDate(dateStr) {
  const d = new Date(dateStr);
  d.setDate(d.getDate() + 1);
  return d.toISOString().slice(0, 10);
}
 
/** 毎月21日に予算を補充する */
function checkMonthlyBudget() {
  const d = new Date(GS.date);
  if (d.getDate() === 21) {
    GS.budget += GS.monthlyBudget;
    addLog("info", `月次予算補充: +${GS.monthlyBudget.toLocaleString()}円`);
  }
}
 
// ─────────────────────────────────────────────
// 毎ターン処理（advanceDay）
// ─────────────────────────────────────────────
 
/**
 * 1日進める。ルールベース処理をすべて実行する。
 * worldSim.js から呼ばれる（LLM呼び出しより先に実行）。
 * @param {object} diff - difficulty.json の該当難易度オブジェクト
 */
export function advanceDay(diff) {
  GS.day  += 1;
  GS.date  = advanceDate(GS.date);
 
  // 予算補充
  checkMonthlyBudget();
 
  // 作戦カウントダウン
  tickOperation();
 
  // バックグラウンド判定
  _rollBackgroundEvents(diff);
 
  // シナリオ固有判定
  checkScenarioMechanics(diff);
}
 
// ─────────────────────────────────────────────
// バックグラウンドイベント判定
// ─────────────────────────────────────────────
 
function _rollBackgroundEvents(diff) {
  // ── リーク判定 ──
  if (!GS.leaks && Math.random() < diff.leakChancePerTurn) {
    GS.leaks = true;
    addLog("alert", "内部情報漏洩が発生した可能性があります。");
  }
 
  // ── 敵カウンター判定 ──
  // 敵警戒度が高いほど Counter Measure リスク上昇
  if (GS.meters.enemyAlertness > 0.6) {
    const pCounter = (GS.meters.enemyAlertness - 0.6) * 0.15;
    if (Math.random() < pCounter) {
      setMeter("exposureRate", GS.meters.exposureRate + 0.05 * diff.exposureMult);
      addLog("warning", "敵による対諜報活動が活発化しています。");
    }
  }
 
  // ── 報道圧力の自然減衰 ──
  if (GS.meters.PressHeat > 0) {
    const decay = 0.01 * diff.pressDecayMult;
    setMeter("PressHeat", GS.meters.PressHeat - decay);
  }
 
  // ── 資金監査圧力の微増 ──
  if (GS.currentOp && GS.meters.auditHeat < 1.0) {
    setMeter("auditHeat", GS.meters.auditHeat + 0.005);
  }
}
 
// ─────────────────────────────────────────────
// 令状・違反処理
// ─────────────────────────────────────────────
 
/**
 * 令状スコア計算
 * S_warrant = valid ? fit * (1 - coverage_overreach) : 0
 * @param {boolean} hasValidWarrant
 * @param {number} fit - 0.0〜1.0（令状範囲と実際の捜査の一致度）
 * @param {number} overreach - 0.0〜1.0（令状範囲超過率）
 * @returns {number} 0.0〜1.0
 */
export function calcWarrantScore(hasValidWarrant, fit = 1.0, overreach = 0.0) {
  if (!hasValidWarrant) return 0;
  return Math.max(0, fit * (1 - overreach));
}
 
/**
 * M_legal を更新する（違反発生時に呼ぶ）
 * @param {string} violationType - VIOLATIONS のキー
 * @param {number} sev - 1〜3
 * @param {object} diff - difficulty オブジェクト
 */
export function applyViolation(violationType, sev = 1, diff) {
  const table = {
    warrant_missing: { mLegalDelta: -0.10, pressHeatDelta: +0.05 },
    overreach:       { mLegalDelta: -0.07, pressHeatDelta: +0.04 },
    custody_break:   { mLegalDelta: -0.05, pressHeatDelta: +0.03 },
    brutality:       { mLegalDelta: -0.15, pressHeatDelta: +0.10 },
  };
 
  const entry = table[violationType];
  if (!entry) return;
 
  const sensitivity = diff?.pressSensitivity ?? 1.0;
  setMeter("M_legal",   GS.meters.M_legal   + entry.mLegalDelta   * sev);
  setMeter("PressHeat", GS.meters.PressHeat + entry.pressHeatDelta * sev * sensitivity);
 
  GS.violations = GS.violations ?? [];
  GS.violations.push({ day: GS.day, type: violationType, sev });
  addLog("alert", `違反記録: ${violationType} (深刻度${sev})`);
}
 
/**
 * 起訴確率計算（sigmoid関数）
 * pCharge = sigmoid(α*readiness + β*judgeBias + γ*pressTilt + ζ*M_legal − δ*procedureFaults)
 * @param {object} params
 * @returns {number} 0.0〜1.0
 */
export function calcChargeProb({
  readiness = 0.5,
  judgeBias = 0,
  pressTilt = 0,
  procedureFaults = 0,
} = {}) {
  const α = 1.2, β = 0.6, γ = 0.4, ζ = 0.8, δ = 0.7;
  const x = α * readiness + β * judgeBias + γ * pressTilt + ζ * GS.meters.M_legal - δ * procedureFaults;
  return 1 / (1 + Math.exp(-x));
}
 
/**
 * 即詰み判定（EXPOSED難易度）
 * @param {object} diff
 * @returns {string|false} 失敗種別 or false
 */
export function checkInstantFail(diff) {
  if (diff.instantFailPolicy !== "Strict") return false;
  const m = GS.meters;
  if (m.M_legal < 0.20 && m.PressHeat >= 0.70)
    return "legal_press_fail";
  if (m.exposureRate >= 0.85 && m.enemyAlertness >= 0.70)
    return "exposure_enemy_fail";
  if (m.chainIntegrity <= 0.60 && GS.violations?.some(v => v.sev >= 2))
    return "chain_violation_fail";
  return false;
}
 
// ─────────────────────────────────────────────
// シナリオ固有判定
// ─────────────────────────────────────────────
 
/**
 * シナリオ固有のメカニクスを毎ターンチェックする
 * @param {object} diff
 */
export function checkScenarioMechanics(diff) {
  const sv = GS.scenarioVars;
  switch (GS.scenarioId) {
    case "scenario_jp2025":   _checkJp2025(sv, diff);  break;
    case "scenario_stasi1985":_checkStasi(sv);          break;
    case "scenario_sid1970":  _checkSid(sv);            break;
    case "scenario_dea1990":  _checkDea(sv);            break;
    case "scenario_kmt1945":  /* 亡命先はプレイヤー選択時に判定 */ break;
  }
}
 
function _checkJp2025(sv, diff) {
  // PublicOpinion は PressHeat・M_legal に連動して変動
  if (sv.publicOpinion === undefined) sv.publicOpinion = 50;
  if (GS.meters.PressHeat > 0.6)  sv.publicOpinion = Math.max(0, sv.publicOpinion - 1);
  if (GS.meters.M_legal < 0.5)    sv.publicOpinion = Math.max(0, sv.publicOpinion - 1);
  if (sv.publicOpinion <= 0) {
    addLog("alert", "世論が限界に達しました。国会追及フラグが立ちました。");
    GS.pendingEndings.push("end_public_fail");
  }
}
 
function _checkStasi(sv) {
  if (sv.paranoiaLevel === undefined) sv.paranoiaLevel = 1;
  sv.paranoiaLevel = Math.max(1.0, sv.paranoiaLevel);  // 0には絶対に戻らない
  if (sv.paranoiaLevel >= 3) addLog("alert", "内部監査が開始されました。");
  if (sv.paranoiaLevel >= 5) {
    addLog("alert", "粛清フラグが立ちました。");
    GS.pendingEndings.push("purge");
  }
}
 
function _checkSid(sv) {
  if (!sv.factionBalance) return;
  const fb = sv.factionBalance;
  if (fb.partiti      >= 90) addLog("alert", "権威主義的危機が迫っています。");
  if (fb.popolo       >= 90) addLog("alert", "ゼネストの兆候があります。");
  if (fb.mafia        >= 90) addLog("alert", "司法暗殺のリスクが高まっています。");
  if (fb.destraViolence  >= 90) addLog("alert", "右翼テロの危険水域です。");
  if (fb.sinistraViolence >= 90) addLog("alert", "武装蜂起の危険水域です。");
}
 
function _checkDea(sv) {
  if (sv.exposure === undefined) sv.exposure = 0;
  if (sv.assassinationRisk === undefined) sv.assassinationRisk = 5;
  if (sv.exposure >= 3) {
    const pAssass = sv.assassinationRisk / 100;
    if (Math.random() < pAssass) {
      addLog("alert", "暗殺未遂事件が発生しました！");
      GS.pendingEndings.push("assassination_attempt");
    }
  }
}
 
// ─────────────────────────────────────────────
// 令状プロセス（scenario_jp2025）
// ─────────────────────────────────────────────
 
/**
 * 作戦の方式を確定し、時間コストと証拠能力を設定する
 * @param {object} op - GS.currentOp
 */
export function processWarrant(op) {
  if (op.method === "legal") {
    // 令状申請 → 時間コスト +2〜3日
    op.days += Math.floor(Math.random() * 2) + 2;
    op.daysRemaining = op.days;
    op.evidenceValid = true;
    addLog("info", `令状申請完了。作戦期間が${op.days}日に延長されました。`);
  } else if (op.method === "illegal") {
    op.evidenceValid = false;
    setMeter("exposureRate", GS.meters.exposureRate + 0.15);
    const sv = GS.scenarioVars;
    sv.illegalOpsCount = (sv.illegalOpsCount ?? 0) + 1;
    addLog("warning", "違法手続きで作戦を開始しました。証拠能力はゼロです。");
  }
}
 
// ─────────────────────────────────────────────
// スコア計算
// ─────────────────────────────────────────────
 
const SCORE_PROFILES = {
  E1: { mission:0.35, legality:0.20, exposure:0.15, civil:0.10, budget:0.08, time:0.05, procedure:0.04, chain:0.03 },
  D1: { mission:0.25, legality:0.15, exposure:0.20, civil:0.10, budget:0.10, time:0.08, procedure:0.06, chain:0.06 },
  X1: { mission:0.20, legality:0.15, exposure:0.25, civil:0.15, budget:0.05, time:0.05, procedure:0.05, chain:0.10 },
};
 
/**
 * evalAxes からトータルスコアとランクを計算して GS に書き込む
 * @param {object} diff
 */
export function calcEvaluation(diff) {
  const profile = SCORE_PROFILES[diff.scoreWeightsProfile] ?? SCORE_PROFILES.D1;
  const axes    = GS.evalAxes;
  let total = 0;
  for (const [key, weight] of Object.entries(profile)) {
    total += (axes[key] ?? 0) * weight;
  }
  GS.evalTotal = Math.round(total);
  GS.evalRank  = total >= 85 ? "S" : total >= 70 ? "A" : total >= 50 ? "B" : "C";
}
 
