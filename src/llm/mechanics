/** 値を 0.0〜1.0 にクランプ */
export const clamp01 = v => Math.max(0.0, Math.min(1.0, v));
 
/** 値を min〜max にクランプ */
export const clamp = (v, min, max) => Math.max(min, Math.min(max, v));